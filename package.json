{
  "name": "social-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Browser automation CLI toolkit for social media platforms without official APIs",
  "workspaces": [
    "core",
    "platforms/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:core": "npm run build -w core",
    "build:xhs": "npm run build -w @social-cli/xhs",
    "build:x": "npm run build -w @social-cli/x",
    "clean": "rm -rf core/dist platforms/*/dist",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
